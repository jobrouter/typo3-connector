{
	"name": "jobrouter/typo3-connector",
	"description": "Connect TYPO3 with the JobRouter® digitalisation platform",
	"license": "GPL-2.0-or-later",
	"type": "typo3-cms-extension",
	"keywords": [
		"TYPO3 CMS",
		"TYPO3 extension",
		"JobRouter"
	],
	"authors": [
		{
			"name": "Chris Müller",
			"role": "Developer"
		}
	],
	"support": {
		"issues": "https://github.com/jobrouter/typo3-connector/issues",
		"source": "https://github.com/jobrouter/typo3-connector",
		"docs": "https://docs.typo3.org/p/jobrouter/typo3-connector/main/en-us/"
	},
	"require": {
		"php": ">=8.2",
		"ext-sodium": "*",
		"jobrouter/rest-client": "^3.2",
		"typo3/cms-backend": "^13.4 || ^14.2",
		"typo3/cms-core": "^13.4 || ^14.2",
		"typo3/cms-fluid": "^13.4 || ^14.2",
		"typo3/cms-frontend": "^13.4 || ^14.2"
	},
	"require-dev": {
		"brotkrueml/coding-standards": "~6.3.1",
		"ergebnis/composer-normalize": "~2.50.0",
		"phpstan/extension-installer": "^1.4",
		"phpstan/phpstan": "2.1.46",
		"phpunit/phpunit": "^11.5 || ^12.5 || ^13.1",
		"rector/rector": "2.4.1",
		"symfony/yaml": "^7.4",
		"symplify/phpstan-rules": "^14.9",
		"tomasvotruba/cognitive-complexity": "^1.1",
		"typo3/testing-framework": "^9.5"
	},
	"suggest": {
		"jobrouter/typo3-data": "Connect JobRouter® JobData tables with TYPO3",
		"jobrouter/typo3-process": "Connect JobRouter® processes with TYPO3"
	},
	"autoload": {
		"psr-4": {
			"JobRouter\\AddOn\\Typo3Connector\\": "Classes"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"JobRouter\\AddOn\\Typo3Connector\\Tests\\": "Tests"
		}
	},
	"config": {
		"allow-plugins": {
			"ergebnis/composer-normalize": true,
			"phpstan/extension-installer": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"bin-dir": ".Build/bin",
		"sort-packages": true,
		"vendor-dir": ".Build/vendor"
	},
	"extra": {
		"branch-alias": {
			"dev-main": "5.0.x-dev"
		},
		"typo3/cms": {
			"Package": {
				"providesPackages": {
					"jobrouter/rest-client": ""
				}
			},
			"extension-key": "jobrouter_connector",
			"version": "5.0.0-dev",
			"web-dir": ".Build/Web"
		}
	}
}
